<DOMAIN>, <WWW_DOMAIN> {
    encode zstd gzip

    handle_path /static/* {
        root * /srv/<APP_NAME>/staticfiles
        file_server
    }

    handle_path /media/* {
        root * /srv/<APP_NAME>/media
        file_server
    }

    reverse_proxy 127.0.0.1:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
